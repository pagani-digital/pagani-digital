# ============================================================
#  PAGANI DIGITAL — Backend
#  Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# Clé secrète JWT — OBLIGATOIRE
# Générez une valeur forte avec :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NE JAMAIS utiliser une valeur simple ou prévisible
JWT_SECRET=REMPLACER_PAR_UN_SECRET_FORT_64_CHARS_HEX

# Durée de validité des tokens vidéo Drive (secondes)
VIDEO_TOKEN_TTL=7200

# Port du serveur
PORT=3001

# Origines autorisées (séparées par virgule)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3001

# === Verification email inscription ===
# Secret pour le hash du code (optionnel, sinon JWT_SECRET)
REG_CODE_SECRET=REMPLACER_PAR_UN_SECRET_FORT
# Duree de validite du code (minutes)
REG_CODE_TTL_MIN=10
# Cooldown avant renvoi du code (secondes)
REG_CODE_RESEND_COOLDOWN_SEC=60
# Liste de domaines jetables a bloquer (separes par virgule)
DISPOSABLE_EMAIL_DOMAINS=

# === SMTP (envoi des codes) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=mot_de_passe_smtp
SMTP_FROM=Pagani Digital <noreply@pagani.digital>

# Compte administrateur (créé au premier démarrage)
ADMIN_EMAIL=admin@paganidigital.com
ADMIN_PASSWORD=ChangeMe2025!
ADMIN_NAME=Admin Pagani
